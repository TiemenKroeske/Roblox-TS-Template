{
  "name": "Roblox-TS-Template",
  "globIgnorePaths": [
    "**/package.json",
    "**/tsconfig.json"
  ],
  "tree": {
    "$className": "DataModel",
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "TS": {
        "$path": "out/server",
        "$ignoreUnknownInstances": true
      },
      "rbxts_include": {
        "$className": "Folder",
        "$path": "include",
        "node_modules": {
          "$className": "Folder",
          "@tiemenkroeske": {
            "$className": "Folder",
            "roblox-ts-package-template": {
              "$className": "Folder",
              "out": {
                "$className": "Folder",
                "server": {
                  "$path": "node_modules/@tiemenkroeske/roblox-ts-package-template/out/server"
                },
                "shared": {
                  "$path": "node_modules/@tiemenkroeske/roblox-ts-package-template/out/shared"
                }
              }
            }
          }
        }
      }
    },
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "rbxts_include": {
        "$className": "Folder",
        "$path": "include",
        "node_modules": {
          "$className": "Folder",
          "@rbxts": {
            "$path": "node_modules/@rbxts"
          },
          "@flamework": {
            "$path": "node_modules/@flamework"
          }
        }
      },
      "TS": {
        "$path": "out/shared"
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "TS": {
          "$path": "out/client",
          "$ignoreUnknownInstances": true
        },
        "rbxts_include": {
          "$className": "Folder",
          "node_modules": {
            "$className": "Folder",
            "@tiemenkroeske": {
              "$className": "Folder",
              "roblox-ts-package-template": {
                "$className": "Folder",
                "out": {
                  "$className": "Folder",
                  "client": {
                    "$path": "node_modules/@tiemenkroeske/roblox-ts-package-template/out/client"
                  },
                  "shared": {
                    "$path": "node_modules/@tiemenkroeske/roblox-ts-package-template/out/shared"
                  }
                }
              }
            }
          }
        }
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "HttpService": {
      "$className": "HttpService",
      "$properties": {
        "HttpEnabled": true
      }
    },
    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}